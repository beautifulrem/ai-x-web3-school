# Copy to .env and fill in. .env is gitignored.

# RPC endpoints (free public RPCs work, or use Alchemy/Infura)
SEPOLIA_RPC_URL=https://sepolia.drpc.org
MAINNET_RPC_URL=https://eth.llamarpc.com

# Etherscan API key (for `forge verify-contract`) — get from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY_HERE

# Test-network deployer private key (NEVER use a key with real funds)
PRIVATE_KEY=0xYOUR_TEST_PRIVATE_KEY

# Optional: greeting message at deploy time
INITIAL_GREETING="GM AI x Web3 School"
